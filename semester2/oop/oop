class Observer
{
public:
	Observer() = default;
	virtual ~Observer() = default;
	virtual void update() = 0;
};


class Subject
{
private:
	vector<Observer*> observers;
public:
	Subject() = default;
	~Subject() = default;
	void registerObserver(Observer* obs) {
		this->observers.emplace_back(obs);
	}
	void notify() {
		for (auto& obs : observers) {
			obs->update();
		}
	}
};

