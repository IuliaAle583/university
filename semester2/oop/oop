class MyFilterModel : public QSortFilterProxyModel {
    Q_OBJECT
    QString filterStatus;

public:
    void setStatusFilter(const QString& status) {
        filterStatus = status;
        invalidateFilter(); //  spune proxy-ului să refacă filtrarea
    }

protected:
    bool filterAcceptsRow(int row, const QModelIndex& parent) const override {
        QModelIndex index = sourceModel()->index(row, 2, parent); // status in col 2
        QString value = sourceModel()->data(index).toString();
        return value == filterStatus;
    }
};
